# Aviator Crash backend environment variables
# Copy this file to .env and fill in real values for production.

# Set to "production" on the VPS
NODE_ENV=production

# Port to listen on (nginx will proxy to this)
PORT=5000

# Generate a long random string for production. Example: openssl rand -hex 64
JWT_SECRET=replace_me_with_a_long_random_string

# Admin login credentials (frontend admin panel uses these)
ADMIN_USERNAME=admin
ADMIN_KEY=change_me_to_a_strong_password

# Comma-separated list of allowed origins for CORS in production.
# Include your live site domain.
ALLOWED_ORIGINS=https://game.idkwhoami.in
